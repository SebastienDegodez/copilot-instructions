---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import { marked } from 'marked';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  // Sort so root skills (id starts with 'skills/') take priority over plugin-bundled duplicates
  const sorted = [...skills].sort((a, b) => {
    const aIsRoot = a.id.startsWith('skills/');
    const bIsRoot = b.id.startsWith('skills/');
    if (aIsRoot && !bIsRoot) return -1;
    if (!aIsRoot && bIsRoot) return 1;
    return 0;
  });
  const seen = new Set<string>();
  return sorted
    .map((skill) => {
      // id format: "skills/skill-name/SKILL" or "plugins/.../skills/skill-name/SKILL"
      const slug = skill.id.split('/').at(-2)!;
      return { params: { slug }, props: { skill } };
    })
    .filter(({ params }) => {
      if (seen.has(params.slug)) return false;
      seen.add(params.slug);
      return true;
    });
}

interface Props {
  skill: any;
}

const { skill } = Astro.props;
const { slug } = Astro.params;

// Function to format skill slug to readable name
function formatSkillName(slug: string): string {
  return slug
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const { Content } = await render(skill);
const title = skill.data.name || formatSkillName(skill.id);
const description = skill.data.description;

// Try to load README.md if it exists
let readmeContent = '';
let hasReadme = false;
try {
  const readmePath = join(process.cwd(), '..', 'skills', slug, 'README.md');
  const readmeText = await readFile(readmePath, 'utf-8');
  readmeContent = await marked(readmeText);
  hasReadme = true;
} catch (error) {
  // README doesn't exist, that's OK
  readmeContent = '<p class="text-slate-400 italic">No README available for this skill.</p>';
}
---

<BaseLayout title={title}>
  <div class="space-y-6">
    <a
      id="back-link"
      href={`${import.meta.env.BASE_URL}skills/`}
      class="inline-block text-blue-400 hover:text-blue-300 font-semibold mb-4"
    >
      ← Back to Skills
    </a>

    <h1 class="text-3xl font-bold text-slate-100">{title}</h1>

    {description && (
      <div class="bg-gradient-to-r from-blue-900/30 to-slate-800 border-l-4 border-blue-500 p-6 rounded-r-lg">
        <h2 class="text-sm uppercase tracking-wide text-blue-300 font-semibold mb-2">Description</h2>
        <p class="text-slate-200 text-lg leading-relaxed">
          {description}
        </p>
      </div>
    )}

    <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
      {/* Tabs Navigation */}
      <div class="flex border-b border-slate-700">
        <button
          id="tab-overview"
          class="tab-button px-6 py-3 font-semibold text-blue-400 border-b-2 border-blue-500 bg-slate-900/50"
          onclick="switchTab('overview')"
        >
          📋 Overview
        </button>
        <button
          id="tab-skill"
          class="tab-button px-6 py-3 font-semibold text-slate-400 hover:text-slate-200 transition"
          onclick="switchTab('skill')"
        >
          📖 SKILL.md
        </button>
      </div>

      {/* Tab: Overview (README) */}
      <div id="content-overview" class="tab-content p-8">
        <article class="prose prose-invert prose-lg max-w-none prose-headings:text-slate-100 prose-h1:text-3xl prose-h2:text-2xl prose-h2:border-b prose-h2:border-slate-700 prose-h2:pb-2 prose-h3:text-xl prose-p:text-slate-300 prose-a:text-blue-400 prose-a:no-underline hover:prose-a:text-blue-300 hover:prose-a:underline prose-strong:text-slate-200 prose-code:text-blue-300 prose-code:bg-slate-900 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-700 prose-ul:text-slate-300 prose-ol:text-slate-300 prose-li:text-slate-300 prose-blockquote:border-blue-500 prose-blockquote:text-slate-400">
          <Fragment set:html={readmeContent} />
        </article>
      </div>

      {/* Tab: SKILL.md */}
      <div id="content-skill" class="tab-content p-8 hidden">
        <article class="prose prose-invert prose-lg max-w-none prose-headings:text-slate-100 prose-h1:text-3xl prose-h2:text-2xl prose-h2:border-b prose-h2:border-slate-700 prose-h2:pb-2 prose-h3:text-xl prose-p:text-slate-300 prose-a:text-blue-400 prose-a:no-underline hover:prose-a:text-blue-300 hover:prose-a:underline prose-strong:text-slate-200 prose-code:text-blue-300 prose-code:bg-slate-900 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-700 prose-ul:text-slate-300 prose-ol:text-slate-300 prose-li:text-slate-300 prose-blockquote:border-blue-500 prose-blockquote:text-slate-400">
          <Content />
        </article>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Client-side: Update back link based on URL parameters
  const urlParams = new URLSearchParams(window.location.search);
  const fromPlugin = urlParams.get('from') === 'plugin';
  const pluginSlug = urlParams.get('plugin');
  
  if (fromPlugin && pluginSlug) {
    const backLink = document.getElementById('back-link');
    if (backLink) {
      const baseUrl = import.meta.env.BASE_URL;
      const formattedName = pluginSlug
        .split('-')
        .map(word => word.charAt(0).toUpperCase() + word.slice(1))
        .join(' ');
      
      backLink.href = `${baseUrl}plugins/${pluginSlug}/`;
      backLink.textContent = `← Back to ${formattedName} Plugin`;
    }
  }

  // Tab switching functionality
  function switchTab(tabName: string) {
    // Hide all tab contents
    const contents = document.querySelectorAll('.tab-content');
    contents.forEach(content => content.classList.add('hidden'));
    
    // Remove active state from all tabs
    const tabs = document.querySelectorAll('.tab-button');
    tabs.forEach(tab => {
      tab.classList.remove('text-blue-400', 'border-b-2', 'border-blue-500', 'bg-slate-900/50');
      tab.classList.add('text-slate-400');
    });
    
    // Show selected tab content
    const selectedContent = document.getElementById(`content-${tabName}`);
    if (selectedContent) {
      selectedContent.classList.remove('hidden');
    }
    
    // Activate selected tab
    const selectedTab = document.getElementById(`tab-${tabName}`);
    if (selectedTab) {
      selectedTab.classList.remove('text-slate-400');
      selectedTab.classList.add('text-blue-400', 'border-b-2', 'border-blue-500', 'bg-slate-900/50');
    }
  }

  // Make switchTab globally accessible
  (window as any).switchTab = switchTab;
</script>
