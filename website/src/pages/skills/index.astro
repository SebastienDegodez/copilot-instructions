---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const skills = await getCollection('skills');

// Sort skills alphabetically by directory name, deduplicating by slug (root skills take priority)
const seen = new Set<string>();
const sortedSkills = skills
  .sort((a, b) => {
    const aIsRoot = a.id.startsWith('skills/');
    const bIsRoot = b.id.startsWith('skills/');
    if (aIsRoot && !bIsRoot) return -1;
    if (!aIsRoot && bIsRoot) return 1;
    return a.id.localeCompare(b.id);
  })
  .filter((skill) => {
    const slug = skill.id.split('/').at(-2)!;
    if (seen.has(slug)) return false;
    seen.add(slug);
    return true;
  })
  .sort((a, b) => {
    const slugA = a.id.split('/').at(-2)!;
    const slugB = b.id.split('/').at(-2)!;
    return slugA.localeCompare(slugB);
  });

// Function to format skill slug to readable name
function formatSkillName(slug: string): string {
  return slug
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}
---

<BaseLayout title="Skills">
  <div class="space-y-6">
    <div class="bg-slate-800 border border-slate-700 p-6 rounded-lg">
      <p class="text-lg text-slate-300">
        Explore specialized capabilities with bundled resources for implementing advanced features and patterns.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        sortedSkills.map((skill) => {
          // skill.id is in format "skills/skill-name/SKILL" or "plugins/.../skills/skill-name/SKILL"
          const skillSlug = skill.id.split('/').at(-2)!;
          return (
          <a
            href={`${import.meta.env.BASE_URL}skills/${skillSlug}/`}
            class="bg-slate-800 border border-slate-700 p-6 rounded-lg hover:shadow-lg hover:border-blue-500 transition duration-300 block"
          >
            <h3 class="text-xl font-bold mb-2 text-blue-400">
              {formatSkillName(skillSlug)}
            </h3>
            {skill.data.description && (
              <p class="text-slate-400 text-sm">
                {skill.data.description}
              </p>
            )}
            {skill.data.tags && skill.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {skill.data.tags.map((tag) => (
                  <span class="inline-block bg-slate-700 text-slate-200 px-3 py-1 rounded-full text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
          );
        })
      }
    </div>
  </div>
</BaseLayout>
