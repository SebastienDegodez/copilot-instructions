---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import { marked } from 'marked';

export async function getStaticPaths() {
  const plugins = await getCollection('plugins');
  return plugins.map((plugin) => {
    // Extract directory name from id (e.g., "csharp-clean-architecture-development/plugin" -> "csharp-clean-architecture-development")
    const slug = plugin.id.split('/')[0];
    return {
      params: { slug },
      props: { plugin, slug },
    };
  });
}

interface Props {
  plugin: any;
  slug: string;
}

const { plugin, slug } = Astro.props;

// Read the README.md file for this plugin
let readmeContent = '';
try {slug
  const readmePath = join(process.cwd(), 'plugins', plugin.id, 'README.md');
  const readmeText = await readFile(readmePath, 'utf-8');
  readmeContent = await marked(readmeText);
} catch (error) {
  readmeContent = '<p class="text-gray-500">No README available for this plugin.</p>';
}
---

<BaseLayout title={plugin.data.name}>
  <div class="space-y-6">
    <a
      href="/copilot-instructions/plugins/"
      class="inline-block text-blue-600 hover:text-blue-800 font-semibold mb-4"
    >
      ← Back to Plugins
    </a>

    <div class="bg-blue-50 p-6 rounded-lg">
      <h1 class="text-3xl font-bold mb-2 text-gray-900">{plugin.data.name}</h1>
      <p class="text-lg text-gray-700 mb-4">{plugin.data.description}</p>
      
      <div class="flex flex-wrap gap-4 text-sm text-gray-600">
        <div>
          <span class="font-semibold">Version:</span> {plugin.data.version}
        </div>
        {plugin.data.author && (
          <div>
            <span class="font-semibold">Author:</span> {plugin.data.author}
          </div>
        )}
        <div>
          <span class="font-semibold">Skills:</span> {plugin.data.skills.length}
        </div>
      </div>

      {plugin.data.tags && plugin.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {plugin.data.tags.map((tag) => (
            <span class="inline-block bg-blue-200 text-blue-900 px-3 py-1 rounded-full text-xs font-semibold">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <div class="bg-white border border-gray-200 p-6 rounded-lg">
      <h2 class="text-2xl font-bold mb-4 text-gray-900">Included Skills</h2>
      <ul class="space-y-2">
        {plugin.data.skills.map((skill) => (
          <li class="flex items-center">
            <svg class="w-5 h-5 mr-2 text-green-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-gray-700">{skill}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="bg-white border border-gray-200 p-6 rounded-lg">
      <h2 class="text-2xl font-bold mb-4 text-gray-900">Installation</h2>
      <div class="bg-gray-50 p-4 rounded border border-gray-300 mb-4">
        <code class="text-sm text-gray-800">
          # Copy the plugin directory to your workspace<br />
          cp -r plugins/{slug} /path/to/your/workspace/plugins/
        </code>
      </div>
      <p class="text-gray-600 text-sm">
        After copying, the plugin skills and configurations will be available in your GitHub Copilot environment.
      </p>
    </div>

    <article class="prose prose-sm sm:prose lg:prose-lg max-w-none">
      <Fragment set:html={readmeContent} />
    </article>
  </div>
</BaseLayout>
