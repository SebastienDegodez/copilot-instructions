---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BenchmarkPanel from '../../components/BenchmarkPanel.astro';

export async function getStaticPaths() {
  const instructions = await getCollection('instructions');
  return instructions.map((instruction) => ({
    params: { slug: instruction.id },
    props: { instruction },
  }));
}

interface Props {
  instruction: any;
}

const { instruction } = Astro.props;

// Function to format instruction slug to readable name
function formatInstructionName(slug: string): string {
  return slug
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const { Content } = await render(instruction);
const title = formatInstructionName(instruction.id);
const description = instruction.data.description;
---

<BaseLayout title={title}>
  <div class="space-y-6">
    <a
      href={`${import.meta.env.BASE_URL}instructions/`}
      class="inline-block text-blue-400 hover:text-blue-300 font-semibold mb-4"
    >
      ← Back to Instructions
    </a>

    {description && (
      <p class="text-slate-400 text-lg mb-6">
        {description}
      </p>
    )}

    {instruction.data.applyTo && (
      <div class="mb-6">
        <span class="inline-block bg-blue-900/50 text-blue-300 px-4 py-2 rounded-full text-sm font-semibold">
          Applies to: {instruction.data.applyTo}
        </span>
      </div>
    )}

    <div class="bg-gray-900 border border-slate-700 rounded-lg overflow-hidden">
      <div class="flex border-b border-slate-700">
        <button id="itab-apm" class="itab px-4 py-2 text-sm font-semibold text-blue-400 border-b-2 border-blue-500 bg-slate-900/50 whitespace-nowrap" onclick="switchItab('apm')">
          📦 APM
        </button>
        <button id="itab-vscode" class="itab px-4 py-2 text-sm font-semibold text-slate-400 hover:text-slate-200 transition whitespace-nowrap" onclick="switchItab('vscode')">
          <svg class="w-4 h-4 inline mr-1" viewBox="0 0 24 24" fill="currentColor"><path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 19.983V4.017a1.5 1.5 0 0 0-.85-1.43zm-5.146 14.861L10.826 12l7.178-5.448v10.896z"/></svg>
          VS Code
        </button>
      </div>
      <div id="icontent-apm" class="icontent p-4">
        <code class="text-sm font-mono text-green-400 block">
          <span class="text-yellow-300">apm install </span><span class="text-blue-400">SebastienDegodez/copilot-instructions/instructions/{instruction.id}.instructions.md</span>
        </code>
      </div>
      <div id="icontent-vscode" class="icontent p-4 hidden flex flex-wrap gap-3">
        <a
          href={`vscode://github.copilot/install?gitRepositoryUrl=https://github.com/SebastienDegodez/copilot-instructions&relativePaths=instructions/${instruction.id}.instructions.md`}
          class="inline-flex items-center gap-2 bg-[#007ACC] text-white px-4 py-2 rounded hover:bg-blue-600 transition text-sm font-semibold"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 19.983V4.017a1.5 1.5 0 0 0-.85-1.43zm-5.146 14.861L10.826 12l7.178-5.448v10.896z"/></svg>
          Open in VS Code
        </a>
        <a
          href={`vscode-insiders://github.copilot/install?gitRepositoryUrl=https://github.com/SebastienDegodez/copilot-instructions&relativePaths=instructions/${instruction.id}.instructions.md`}
          class="inline-flex items-center gap-2 bg-[#24BC5B] text-white px-4 py-2 rounded hover:bg-green-600 transition text-sm font-semibold"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 19.983V4.017a1.5 1.5 0 0 0-.85-1.43zm-5.146 14.861L10.826 12l7.178-5.448v10.896z"/></svg>
          Open in VS Code Insiders
        </a>
      </div>
    </div>

    <div class="bg-slate-800 border border-slate-700 rounded-lg p-8">
      <article class="prose prose-invert prose-lg max-w-none prose-headings:text-slate-100 prose-h1:text-3xl prose-h2:text-2xl prose-h2:border-b prose-h2:border-slate-700 prose-h2:pb-2 prose-h3:text-xl prose-p:text-slate-300 prose-a:text-blue-400 prose-a:no-underline hover:prose-a:text-blue-300 hover:prose-a:underline prose-strong:text-slate-200 prose-code:text-blue-300 prose-code:bg-slate-900 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-700 prose-ul:text-slate-300 prose-ol:text-slate-300 prose-li:text-slate-300 prose-blockquote:border-blue-500 prose-blockquote:text-slate-400">
        <Content />
      </article>
    </div>

    <BenchmarkPanel assetId={`instruction:${instruction.id}`} />
  </div>
</BaseLayout>

<script>
  function switchItab(name: string) {
    document.querySelectorAll('.icontent').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.itab').forEach(el => {
      el.classList.remove('text-blue-400', 'border-b-2', 'border-blue-500', 'bg-slate-900/50');
      el.classList.add('text-slate-400');
    });
    document.getElementById(`icontent-${name}`)?.classList.remove('hidden');
    const tab = document.getElementById(`itab-${name}`);
    if (tab) {
      tab.classList.remove('text-slate-400');
      tab.classList.add('text-blue-400', 'border-b-2', 'border-blue-500', 'bg-slate-900/50');
    }
  }
  (window as any).switchItab = switchItab;
</script>
