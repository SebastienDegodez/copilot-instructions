---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const instructions = await getCollection('instructions');
  return instructions.map((instruction) => ({
    params: { slug: instruction.id },
    props: { instruction },
  }));
}

interface Props {
  instruction: any;
}

const { instruction } = Astro.props;

// Function to format instruction slug to readable name
function formatInstructionName(slug: string): string {
  // Remove .instructions suffix if present
  const cleanSlug = slug.replace(/\.instructions$/, '');
  return cleanSlug
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const { Content } = await render(instruction);
const title = formatInstructionName(instruction.id);
const description = instruction.data.description;
---

<BaseLayout title={title}>
  <div class="space-y-6">
    <a
      href={`${import.meta.env.BASE_URL}instructions/`}
      class="inline-block text-blue-600 hover:text-blue-800 font-semibold mb-4"
    >
      ← Back to Instructions
    </a>

    {description && (
      <p class="text-gray-600 text-lg mb-6">
        {description}
      </p>
    )}

    {instruction.data.applyTo && (
      <div class="mb-6">
        <span class="inline-block bg-blue-100 text-blue-800 px-4 py-2 rounded-full text-sm font-semibold">
          Applies to: {instruction.data.applyTo}
        </span>
      </div>
    )}

    <article class="prose prose-sm sm:prose lg:prose-lg max-w-none">
      <Content />
    </article>
  </div>
</BaseLayout>
