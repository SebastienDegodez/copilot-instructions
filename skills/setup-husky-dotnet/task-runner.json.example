{
  "version": 1,
  "tasks": [
    {
      "name": "commit-message-linter",
      "description": "Validates commit messages against conventional commit format",
      "command": "dotnet",
      "args": ["husky", "exec", ".husky/csx/commit-lint.csx", "--args", "${args}"]
    },
    {
      "name": "dotnet-format",
      "description": "Formats C# code in staged files",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["dotnet-format", "--include", "${staged}"],
      "include": ["**/*.cs", "**/*.vb"]
    }
  ]
}
